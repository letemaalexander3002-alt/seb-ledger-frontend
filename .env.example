# Copy this file to .env.local and adjust to match your running
# seb-ledger-core (Express/Supabase) backend.

# Base URL the frontend will call for all API requests.
# Leave as "/api/v1" to use the Vite dev-server proxy defined in
# vite.config.js (which forwards "/api" to VITE_BACKEND_URL below).
# Set to a full origin (e.g. https://api.sebledger.tz/api/v1) for
# production builds where the frontend and backend are on different hosts.
VITE_API_BASE_URL=/api/v1

# Used only by vite.config.js's dev-server proxy target.
# seb-ledger-core defaults to PORT=3000 — match that here.
VITE_BACKEND_URL=http://localhost:3000

# Optional. Only needed if the backend has ADMIN_API_KEY set, in which
# case it's required to load GET /api/v1/governance/dashboard. Leave
# blank if the backend doesn't enforce this (e.g. local development).
VITE_ADMIN_API_KEY=
